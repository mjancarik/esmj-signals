{
  "name": "@esmj/signals",
  "version": "0.3.0",
  "description": "Tiny reactive signals.",
  "keywords": [
    "signals",
    "reactive",
    "effect",
    "computed"
  ],
  "main": "dist/index",
  "module": "dist/index",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./debug": {
      "types": "./dist/debug.d.ts",
      "import": "./dist/debug.mjs",
      "require": "./dist/debug.cjs"
    }
  },
  "sideEffects": false,
  "typings": "dist/index.d.ts",
  "scripts": {
    "lint": "biome check --no-errors-on-unmatched",
    "lint:fix": "npm run lint -- --fix --unsafe",
    "dev": "node_modules/.bin/tsup --dts --watch --onSuccess 'node ./dist/index.mjs'",
    "test": "node --test",
    "test:watch": "npm run test -- --watchAll",
    "preversion": "npm test && npm run lint && npm run build",
    "version": "npm run changelog && git add CHANGELOG.md",
    "postversion": "git push && git push --tags",
    "commit": "node_modules/.bin/git-cz",
    "changelog": "node_modules/.bin/conventional-changelog -p angular -i CHANGELOG.md -s -r 1",
    "build": "node_modules/.bin/tsup --dts && cp src/index.d.ts dist/index.d.ts",
    "prepare": "husky install"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mjancarik/esmj-signals.git"
  },
  "author": "Miroslav Jancarik",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mjancarik/esmj-signals/issues"
  },
  "lint-staged": {
    "**/*.{ts,js,mjs}": "npm run lint"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "config": {
    "commitizen": {
      "path": "git-cz"
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "homepage": "https://github.com/mjancarik/esmj-signals#readme",
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "commitizen": "^4.3.1",
    "conventional-changelog-cli": "^5.0.0",
    "cz-conventional-changelog": "^3.3.0",
    "git-cz": "^4.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.6",
    "tsup": "^8.5.1"
  },
  "dependencies": {
    "@esmj/observable": "^0.4.0"
  }
}
